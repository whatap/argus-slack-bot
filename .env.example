# ── Slack 인증 — 두 모드 중 하나 ─────────────────────────────
#
# [모드 1] Single-workspace (개발/내부용 — Socket Mode 만)
# 한 워크스페이스 전용. SLACK_BOT_TOKEN 만 있으면 됨.
SLACK_BOT_TOKEN=xoxb-...
# Socket Mode 용 App-Level Token (둘 모드 공통 필수)
SLACK_APP_TOKEN=xapp-...
#
# [모드 2] Multi-workspace OAuth distribution (외부 고객 워크스페이스 설치)
# 셋 다 있으면 multi-workspace 모드 자동 활성. 위 SLACK_BOT_TOKEN 미사용.
# api.slack.com/apps → 앱 선택 → "Manage Distribution" 활성 + Basic Information
# 페이지에서 Client ID / Client Secret / Signing Secret 발급.
# SLACK_STATE_SECRET 은 OAuth state 서명용 임의 문자열 (`openssl rand -hex 32`).
# Slack 앱 설정 → OAuth & Permissions → Redirect URLs 에
# https://<public-host>/slack/oauth_redirect 등록 필요.
# SLACK_CLIENT_ID=...
# SLACK_CLIENT_SECRET=...
# SLACK_SIGNING_SECRET=...
# SLACK_STATE_SECRET=...
# SLACK_OAUTH_PORT=3000   # OAuth 콜백 HTTP 서버 포트 (기본 3000)

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=8192

# ── whatap-open-mcp-aitf 자식 프로세스 진입점 ─────────────────
# bot 이 stdio 로 spawn 할 MCP 서버 (per-request 마다 fresh spawn)
WHATAP_MCP_PATH=/Users/jaeyoung/work/whatap-open-mcp-aitf/dist/cli.js

# 사용자 토큰을 안 줬을 때의 default WHATAP_API_URL.
# 내부 운영: https://dev.whatap.io / customer SaaS: https://api.whatap.io
DEFAULT_WHATAP_API_URL=https://dev.whatap.io

# ── argus (옵션, ask_whatap_expert 도구 활성화) ───────────────
# 봇 운영측이 들고있는 단일 argus 인스턴스. 사용자별 cookie 와 함께 사용됨.
# 둘 다 있어야 MCP 의 ask_whatap_expert 가 노출됨.
ARGUS_URL=http://localhost:8090
ARGUS_API_TOKEN=test-mcp-token-abc123

# ── 사용자 토큰 + workspace 설치 저장소 ───────────────────────
# Slack user_id → WhaTap creds 매핑 SQLite. 기본 ./data/user_tokens.sqlite
SLACK_USER_TOKENS_DB=./data/user_tokens.sqlite
# Workspace OAuth 설치 저장소 (multi-workspace 모드만 사용). 위와 같은 파일 OK.
SLACK_INSTALLATIONS_DB=./data/user_tokens.sqlite

# ── Bot 동작 옵션 ─────────────────────────────────────────────
# 도구 호출 최대 hop. argus 가 자체 FC loop 도 돌려서 4-6 면 충분.
MAX_TOOL_HOPS=8
# 한 thread 의 history 최대 turn 수. 초과시 최근 N turn 만 유지.
MAX_HISTORY_TURNS=10
