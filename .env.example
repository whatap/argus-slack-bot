# ── Slack ─────────────────────────────────────────────────────
# https://api.slack.com/apps 에서 앱 생성 후 발급. README 참고.
# Bot User OAuth Token — chat:write, app_mentions:read, im:* 권한
SLACK_BOT_TOKEN=xoxb-...
# App-Level Token — Socket Mode 용 (scope: connections:write)
SLACK_APP_TOKEN=xapp-...

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=8192

# ── whatap-open-mcp-aitf 자식 프로세스 env ────────────────────
# bot 이 stdio 로 spawn 할 MCP 서버 진입점
WHATAP_MCP_PATH=/Users/jaeyoung/work/whatap-open-mcp-aitf/dist/cli.js

# whatap-mcp 가 시작 시 required 로 검사 (api.whatap.io account token).
# 현재 dev 환경에선 invalid 라도 ARGUS_COOKIE 경로로 동작 가능.
WHATAP_API_TOKEN=JMC9V4LLLPGPUQUWVN6Z

# ARGUS_URL + ARGUS_API_TOKEN 둘 다 있어야 ask_whatap_expert 도구 노출됨
ARGUS_URL=http://localhost:8090
ARGUS_API_TOKEN=test-mcp-token-abc123

# argus 가 dev.whatap.io 에 cookie pass-through 할 때 필요. 며칠~수주 만료.
# 만료 시 브라우저 dev tools → Application → Cookies 에서 새 값 추출.
ARGUS_COOKIE=JSESSIONID=...

# ── Bot 동작 옵션 ─────────────────────────────────────────────
# 도구 호출 최대 hop. argus 가 자체 FC loop 도 돌려서 4-6 면 충분.
MAX_TOOL_HOPS=8
# 한 thread 의 history 최대 turn 수. 초과시 최근 N turn 만 유지.
MAX_HISTORY_TURNS=10
